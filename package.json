  "scripts": {
    "astro": "astro",
    "build": "pnpm run convert:images && pnpm run build:astro && pnpm run check && pnpm test:ci",
    "build:astro": "astro build",
    "check": "pnpm run '/^(check:.*)$/'",
    "check:astro": "astro check",
    "check:lint": "eslint 'src/**/*.{js,jsx,ts,tsx,astro}'",
    "check:mdx": "mdx-local-link-checker src/content src/content '**/zerotier-start.sh|/articles/**/*.gif|/articles/**/*.avif|/articles/spell-checker/**/*|/articles/ajax-polling/**/*.zip|/articles/web-application-security/**/*'",
    "check:types:test": "tsc --project ./tests/tsconfig.json",
    "convert:images": "node ./scripts/convert-images.ts",
    "dev": "astro dev",
    "preview": "astro preview",
    "test": "playwright test",
    "test:ci": "CI=1 playwright test --forbid-only --reporter=dot",
    "test:dev": "playwright test --ui",
    "test:setup": "playwright install --with-deps"
  },
